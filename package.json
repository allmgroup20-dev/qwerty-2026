{
  "name": "jobayer-group-career",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "next build && opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "pages:deploy": "npx @cloudflare/next-on-pages",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply jobayer-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply jobayer-db --remote",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next-i18next": "^15.0.0",
    "i18next": "^24.0.0",
    "react-i18next": "^15.0.0",
    "drizzle-orm": "^0.38.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "zustand": "^5.0.0",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.6.0",
    "framer-motion": "^11.0.0",
    "react-hot-toast": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/jsonwebtoken": "^9.0.0",
    "typescript": "^5.7.0",
    "tailwindcss": "^4.0.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@opennextjs/cloudflare": "^1.0.0",
    "wrangler": "^4.0.0",
    "@cloudflare/workers-types": "^5.20260708.1",
    "drizzle-kit": "^0.30.0"
  }
}
