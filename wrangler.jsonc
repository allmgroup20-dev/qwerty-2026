{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jobayer-group-career",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-12",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "JWT_SECRET": "your-super-secret-key-change-in-production",
    "DEFAULT_CURRENCY": "BDT",
    "SITE_NAME": "Jobayer Group Career",
    "SITE_URL": "https://jobayer-group-career.workers.dev"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "jgcareer-db",
      "database_id": "534339da-b5c4-41f8-bcfb-978dc453d83d"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "3263fd155e8b4031b6275c7fb2d88d8b"
    }
  ]
}
